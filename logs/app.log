                    WHEN COALESCE(g.reembolso_vendedor,0)=1 THEN 'reembolso'
                    WHEN COALESCE(g.boletos_aereos,0)=1 THEN 'tarjeta_boletos'
                    WHEN COALESCE(g.tarjeta_sin_soporte,0)=1 THEN 'tarjeta_online'
                    ELSE 'tarjeta'
