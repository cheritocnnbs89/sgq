                        AND CAST(pv.valor AS NVARCHAR(MAX)) = CAST(d.motivo AS NVARCHAR(MAX))
                        WHERE d.gasto_id = g.id
                    ) AS m
                ) AS motivos_detalle,

                u.username AS usuario_username,
                u.departamento_id AS usuario_departamento_id,
                g.sap_contabilizacion,
