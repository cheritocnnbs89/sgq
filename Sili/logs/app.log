                        COALESCE(f.pto_emi, '') + '-' +
                        RIGHT(
                            REPLICATE('0', 9) +
                            CAST(CAST(COALESCE(f.secuencial, '0') AS INT) AS VARCHAR(9)),
                            9
                        )
                ))
            )
        
            ORDER BY
                TRY_CONVERT(
                    date,
                    SUBSTRING(f.fecha_emision, 7, 4) + '-' +
                    SUBSTRING(f.fecha_emision, 4, 2) + '-' +
