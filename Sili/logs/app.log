                g.servicios_10,
                g.subtotal_sin_iva,
                g.iva,
                g.total_con_iva,
                g.archivo,
                g.proveedor_id,
                g.usuario_id,
                g.ccb,
                t.identificacion,
                COALESCE(t.nombre, g.proveedor) AS proveedor_nombre,
                COALESCE(g.gg_aprobado, 0) AS gg_aprobado,
