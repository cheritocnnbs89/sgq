            ORDER BY
                TRY_CONVERT(
                    date,
                    SUBSTRING(f.fecha_emision, 7, 4) + '-' +
                    SUBSTRING(f.fecha_emision, 4, 2) + '-' +
                    SUBSTRING(f.fecha_emision, 1, 2)
                ) DESC,
                f.id DESC
