            SELECT
                f.*,
                CASE
                    WHEN EXISTS (
                        SELECT 1
                        FROM terceros t
                        WHERE t.tipo = 'P'
                        AND t.activo = 1
                        AND LTRIM(RTRIM(t.identificacion)) = LTRIM(RTRIM(f.ruc_emisor))
                    ) THEN 1
                    ELSE 0
                END AS proveedor_ok
            FROM facturas_xml f
            WHERE 1 = 1
            ORDER BY TRY_CONVERT(date, SUBSTRING(f.fecha_emision, 7, 4) + '-' + SUBSTRING(f.fecha_emision, 4, 2) + '-' + SUBSTRING(f.fecha_emision, 1, 2)) DESC, f.id DESC
