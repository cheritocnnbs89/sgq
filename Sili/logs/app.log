                        WHERE a.gasto_id = g.id
                    ) THEN 1
                    ELSE 0
                END AS has_adjuntos
             
                FROM gastos_tarjeta g
                LEFT JOIN terceros t ON t.id = g.proveedor_id
                LEFT JOIN usuarios u ON u.id = g.usuario_id
                LEFT JOIN usuarios uga ON uga.id = g.ga_aprobado_por
