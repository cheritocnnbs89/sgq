            SELECT TOP (3)
                f.*,
                CASE
                    WHEN EXISTS (
                        SELECT 1
                        FROM terceros t
                        WHERE UPPER(LTRIM(RTRIM(COALESCE(t.tipo, '')))) = 'P'
                        AND COALESCE(t.activo, 1) = 1
                        AND LTRIM(RTRIM(COALESCE(t.identificacion, ''))) = LTRIM(RTRIM(COALESCE(f.ruc_emisor, '')))
                    ) THEN 1
                    ELSE 0
                END AS proveedor_ok
            FROM facturas_xml f
            WHERE 1 = 1 AND f.estado = 'PENDIENTE' AND 
