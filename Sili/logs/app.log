                COALESCE(g.ga_aprobado, 0) AS ga_aprobado,
                COALESCE(g.tarjeta_sin_soporte,0) AS tarjeta_sin_soporte,
                COALESCE(g.boletos_aereos,0) AS boletos_aereos,

                (
                    SELECT STRING_AGG(m.x, ', ')
