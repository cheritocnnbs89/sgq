-- crea tabla nueva con el MISMO esquema que usas en tu app
CREATE TABLE terceros_new (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  tipo TEXT NOT NULL CHECK(tipo IN ('C','P')),
  nombre TEXT NOT NULL,
  identificacion TEXT,
  email TEXT,
  telefono TEXT,
  direccion TEXT,
  activo INTEGER NOT NULL DEFAULT 1,
  codigo_sap TEXT,
  observaciones TEXT
);

-- copia los datos. Si falla por filas corruptas, prueba por rangos o con OR IGNORE
INSERT INTO terceros_new (id,tipo,nombre,identificacion,email,telefono,direccion,activo,codigo_sap,observaciones)
SELECT id,tipo,nombre,identificacion,email,telefono,direccion,activo,codigo_sap,observaciones
FROM terceros
WHERE id IS NOT NULL;

-- intercambia tablas
ALTER TABLE terceros RENAME TO terceros_bad;
ALTER TABLE terceros_new RENAME TO terceros;

-- recrea índices útiles (los auto-índice de PK/UNIQUE se crean solos)
CREATE INDEX IF NOT EXISTS idx_terceros_tipo   ON terceros(tipo);
CREATE INDEX IF NOT EXISTS idx_terceros_nombre ON terceros(nombre COLLATE NOCASE);

COMMIT;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
