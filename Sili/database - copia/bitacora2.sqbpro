<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="bitacora.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="5624"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="configuracion" custom_title="0" dock_id="2" table="4,13:mainconfiguracion"/><table title="config" custom_title="0" dock_id="1" table="4,6:mainconfig"/><table title="usuarios" custom_title="0" dock_id="3" table="4,8:mainusuarios"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings><table schema="main" name="configuracion" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="199"/><column index="2" value="183"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="usuarios" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="35"/><column index="2" value="95"/><column index="3" value="111"/><column index="4" value="199"/><column index="5" value="151"/><column index="6" value="109"/><column index="7" value="55"/><column index="8" value="99"/><column index="9" value="159"/><column index="10" value="120"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">-- 1) Preferencias por usuario (canales y horarios)
CREATE TABLE IF NOT EXISTS notify_user_prefs(
  user_id       INTEGER PRIMARY KEY REFERENCES usuarios(id) ON DELETE CASCADE,
  email_on      INTEGER NOT NULL DEFAULT 1,
  inapp_on      INTEGER NOT NULL DEFAULT 1,
  slack_on      INTEGER NOT NULL DEFAULT 0,
  slack_webhook TEXT,
  quiet_start   TEXT,   -- '22:00'
  quiet_end     TEXT,   -- '07:00'
  daily_time    TEXT,   -- '08:30' (para resumen diario)
  weekly_dow    INTEGER, -- 1..7 (ISO) para resumen semanal
  weekly_time   TEXT    -- '09:00'
);

-- 2) Plantillas de notificación (aprovecha tu sistema actual de templates)
CREATE TABLE IF NOT EXISTS notify_templates(
  key     TEXT PRIMARY KEY,
  subject TEXT NOT NULL,
  html    TEXT NOT NULL,
  text    TEXT
);

-- Carga algunos keys base si faltan
-- tarea_recordatorio_pre, tarea_hoy, tarea_pendiente_fin_dia, tarea_escalamiento, evidencia_recibida, resumen_diario, resumen_semanal, resumen_mensual

-- 3) Cola de envíos (planner escribe, dispatcher envía)
CREATE TABLE IF NOT EXISTS notify_queue(
  id            INTEGER PRIMARY KEY AUTOINCREMENT,
  user_id       INTEGER NOT NULL REFERENCES usuarios(id) ON DELETE CASCADE,
  tarea_id      INTEGER REFERENCES plan_tareas(id) ON DELETE CASCADE,
  tipo          TEXT NOT NULL,     -- 'pre', 'hoy', 'nudge', 'escalamiento', 'resumen_diario', etc.
  fecha_obj     DATE NOT NULL,     -- fecha a la que corresponde la alerta (día de la tarea)
  canal         TEXT NOT NULL,     -- 'email','inapp','slack'
  template_key  TEXT NOT NULL REFERENCES notify_templates(key),
  payload_json  TEXT,              -- contexto serializado
  estado        TEXT NOT NULL DEFAULT 'pending', -- pending|sent|error|skipped
  scheduled_at  TEXT NOT NULL DEFAULT (datetime('now')),
  sent_at       TEXT,
  error_msg     TEXT,
  UNIQUE(user_id, tarea_id, tipo, fecha_obj, canal)  -- idempotencia
);

-- 4) In-app notifications (si quieres “campanita”)
CREATE TABLE IF NOT EXISTS notify_inapp(
  id        INTEGER PRIMARY KEY AUTOINCREMENT,
  user_id   INTEGER NOT NULL REFERENCES usuarios(id) ON DELETE CASCADE,
  title     TEXT NOT NULL,
  body      TEXT NOT NULL,
  created_at TEXT NOT NULL DEFAULT (datetime('now')),
  read_at   TEXT
);
</sql><current_tab id="0"/></tab_sql></sqlb_project>
