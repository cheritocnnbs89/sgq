CREATE TABLE IF NOT EXISTS user_sequences (
  usuario_id INTEGER NOT NULL,
  key TEXT NOT NULL,
  next_value INTEGER NOT NULL DEFAULT 1,
  updated_at TEXT NOT NULL DEFAULT (datetime('now')),
  PRIMARY KEY (usuario_id, key)
);



