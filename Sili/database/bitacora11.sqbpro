ALTER TABLE gastos_tarjeta ADD COLUMN reembolso_vendedor INTEGER NOT NULL DEFAULT 0;
ALTER TABLE usuarios ADD COLUMN tiene_caja_chica INTEGER NOT NULL DEFAULT 0;
ALTER TABLE usuarios ADD COLUMN codigo_sap TEXT;
ALTER TABLE gastos_tarjeta ADD COLUMN es_caja_chica INTEGER DEFAULT 0;
ALTER TABLE tareas ADD COLUMN porcentaje_avance INTEGER DEFAULT 0;
ALTER TABLE tareas ADD COLUMN empresa_id INTEGER REFERENCES empresas(id);



CREATE TABLE IF NOT EXISTS secuencias_sap (
    nombre TEXT PRIMARY KEY,
    ultimo_valor INTEGER
	
	
);

-- Inicializamos con el valor anterior al que necesitas (20781)
INSERT OR IGNORE INTO secuencias_sap (nombre, ultimo_valor) VALUES ('reembolsos', 20781);

select * from tareas;


     SELECT id, titulo, descripcion, estado, fecha_inicio, 
                fecha_compromiso, fecha_cierre_real, usuario_id, 
                fecha_fin, creador_id, solicitante_id,
                tipo_tarea_id,porcentaje_avance
            FROM tareas
			
			
			
			
			
			
			SELECT
            g.id, g.fecha, g.motivo, g.centro_costo, g.orden_compra,
            g.con_soporte, g.sin_soporte, g.subtotal_factura,
            g.servicios_10, g.subtotal_sin_iva, g.iva, g.total_con_iva, g.archivo,       
            g.proveedor_id, g.usuario_id, g.ccb, t.identificacion,
            COALESCE(t.nombre, g.proveedor) AS proveedor_nombre,
            COALESCE(g.gg_aprobado, 0) AS gg_aprobado,
            COALESCE(g.gf_aprobado, 0) AS gf_aprobado,
            COALESCE(g.ga_aprobado, 0) AS ga_aprobado,
            u.username AS usuario_username,
            u.departamento_id AS usuario_departamento_id,
            g.sap_contabilizacion,
            uga.username AS ga_aprobado_por_username,
            ugg.username AS gg_aprobado_por_username,
            ugf.username AS gf_aprobado_por_username,
            CASE
                WHEN COALESCE(g.es_caja_chica,0)=1 THEN 'caja_chica'
                WHEN COALESCE(g.reembolso_vendedor,0)=1 THEN 'reembolso'
                ELSE 'tarjeta'
            END AS tipo_gasto,
            CASE
                WHEN COALESCE(g.es_caja_chica,0)=1 OR COALESCE(g.reembolso_vendedor,0)=1 THEN 'gg'
                ELSE 'ga'
            END AS ga_actor

            FROM gastos_tarjeta g
            LEFT JOIN terceros t ON t.id = g.proveedor_id
            LEFT JOIN usuarios u ON u.id = g.usuario_id
            LEFT JOIN usuarios uga ON uga.id = g.ga_aprobado_por
            LEFT JOIN usuarios ugg ON ugg.id = g.gg_aprobado_por
            LEFT JOIN usuarios ugf ON ugf.id = g.gf_aprobado_por
			where u.username='atorres';
			
			UPDATE secuencias_sap SET ultimo_valor = ultimo_valor + 1
			 SELECT * FROM usuarios 
			 update usuarios set email='jchavez1@quimpac.com.ec';
			 
			
			
			
			
			
			
			
			
			
	-- 1) Paso temporal (único)
UPDATE usuarios
SET email = 'tmp_' || id || '@quimpac.com.ec';

-- 2) Paso final (definitivo)
WITH ranked AS (
  SELECT id, row_number() OVER (ORDER BY id) AS rn
  FROM usuarios
)
UPDATE usuarios
SET email = 'jchavez' || (SELECT rn FROM ranked WHERE ranked.id = usuarios.id) || '@quimpac.com.ec'
WHERE id IN (SELECT id FROM ranked);


ALTER TABLE gastos_tarjeta
ADD COLUMN tarjeta_sin_soporte INTEGER NOT NULL DEFAULT 0;



CREATE TABLE IF NOT EXISTS user_sequences (
  usuario_id INTEGER NOT NULL,
  key TEXT NOT NULL,
  next_value INTEGER NOT NULL DEFAULT 1,
  updated_at TEXT NOT NULL DEFAULT (datetime('now')),
  PRIMARY KEY (usuario_id, key)
);





SELECT
            g.id, g.fecha, g.motivo, g.centro_costo, g.orden_compra,
            g.con_soporte, g.sin_soporte, g.subtotal_factura,
            g.servicios_10, g.subtotal_sin_iva, g.iva, g.total_con_iva, g.archivo,
            g.proveedor_id, g.usuario_id, g.ccb, t.identificacion,
            COALESCE(t.nombre, g.proveedor) AS proveedor_nombre,
            COALESCE(g.gg_aprobado, 0) AS gg_aprobado,
            COALESCE(g.gf_aprobado, 0) AS gf_aprobado,
            COALESCE(g.ga_aprobado, 0) AS ga_aprobado,
            COALESCE(g.tarjeta_sin_soporte,0) AS tarjeta_sin_soporte,
COALESCE(md.motivos_detalle, '') AS motivos_detalle,

 u.username AS usuario_username,
            u.departamento_id AS usuario_departamento_id,
            g.sap_contabilizacion,
            uga.username AS ga_aprobado_por_username,
            ugg.username AS gg_aprobado_por_username,
            ugf.username AS gf_aprobado_por_username,
            CASE
                WHEN COALESCE(g.es_caja_chica,0)=1 THEN 'caja_chica'
                WHEN COALESCE(g.reembolso_vendedor,0)=1 THEN 'reembolso'

                ELSE 'tarjeta'
            END AS tipo_gasto,
            'ga' AS ga_actor


            FROM gastos_tarjeta g
            LEFT JOIN terceros t ON t.id = g.proveedor_id
            LEFT JOIN usuarios u ON u.id = g.usuario_id
            LEFT JOIN usuarios uga ON uga.id = g.ga_aprobado_por
            LEFT JOIN usuarios ugg ON ugg.id = g.gg_aprobado_por
            LEFT JOIN usuarios ugf ON ugf.id = g.gf_aprobado_por
            LEFT JOIN gastos_tarjeta_detalle gd ON gd.gasto_id = g.id
			LEFT JOIN (
  SELECT gasto_id,
         GROUP_CONCAT(DISTINCT motivo) AS motivos_detalle
  FROM gastos_tarjeta_detalle
  GROUP BY gasto_id
) d ON d.gasto_id = g.id

LEFT JOIN (
  SELECT
    gd.gasto_id,
    GROUP_CONCAT(DISTINCT pv.nombre) AS motivos_detalle
  FROM gastos_tarjeta_detalle gd
  LEFT JOIN param_values pv
    ON pv.valor = gd.motivo
   AND pv.group_id = 1
   AND pv.activo = 1
  GROUP BY gd.gasto_id
) md ON md.gasto_id = g.id
