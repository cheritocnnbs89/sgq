select * from tarea_acciones
-- Agregar usuario asignado al paso
ALTER TABLE tarea_acciones ADD COLUMN usuario_asignado_id INTEGER

-- Agregar estado específico para este paso
ALTER TABLE tarea_acciones ADD COLUMN estado_accion VARCHAR(50) DEFAULT 'En proceso';

-- Agregar fecha inicio (cuando se crea el registro)
ALTER TABLE tarea_acciones ADD COLUMN fecha_inicio DATETIME;

-- Agregar fecha fin tentativa (planificada)
ALTER TABLE tarea_acciones ADD COLUMN fecha_fin_tentativa DATETIME;







-- 1. Lo quitamos para desbloquear el ALTER TABLE
DROP INDEX IF EXISTS uq_notify_gasto_event;

-- 2. Agregamos las columnas de tareas (esto ya no dará error)
ALTER TABLE tarea_acciones ADD COLUMN usuario_asignado_id INTEGER;
ALTER TABLE tarea_acciones ADD COLUMN estado_accion TEXT DEFAULT 'En proceso';
ALTER TABLE tarea_acciones ADD COLUMN fecha_inicio DATETIME;
ALTER TABLE tarea_acciones ADD COLUMN fecha_fin_tentativa DATETIME;

-- 3. Lo volvemos a crear (aquí te pongo la forma estándar que suele tener)
-- Si el paso A te dio un SQL diferente, usa ese.
CREATE UNIQUE INDEX uq_notify_gasto_event 
ON notify_eventos (referencia_id, tipo_evento) 
WHERE procesado = 0;



